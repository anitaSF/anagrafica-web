---
const email = "anagrafica.grafica@gmail.com";
const tlf = "+34 649 29 61 96";
const linkedinUrl = "https://linkedin.com/in/anagrafica";
const githubUrl = "https://github.com/anitaSF";

// Cambia a 'bg-[#C46767]' si prefieres el rosa empolvado
const circleColorClass = "bg-[#0E7675]"; 
---

<footer id="contact" class="w-full max-w-[1500px] mx-auto px-6 lg:px-16 pt-32 pb-12 font-sans overflow-hidden">
  <div class="relative grid grid-cols-1 md:grid-cols-[1.2fr,1fr] items-center gap-12 border-b border-slate-100 pb-24 mb-12">
    
    <div class="relative z-10">
      <div class="relative inline-block mb-8">
        <div class={`absolute -top-12 -left-12 w-32 h-32 md:w-40 md:h-40 rounded-full ${circleColorClass} opacity-95 mix-blend-multiply md:mix-blend-normal z-0`}></div>
        
        <h2 class="relative z-10 text-[clamp(2.5rem,5vw,4.5rem)] font-light tracking-tighter leading-[1.05] text-slate-950">
          ¿Hablamos? <br />Conectemos_
        </h2>
      </div>

      <p class="text-base md:text-lg font-light text-slate-600 leading-relaxed max-w-xl">
        Si buscas un perfil híbrido que fusione la dirección de arte y la sensibilidad visual con un desarrollo front-end sólido (Angular, React, WordPress), hablemos. Te invito a <a href="/about" class="text-slate-950 font-normal underline decoration-brand-coral/40 hover:decoration-brand-coral underline-offset-4 transition-colors">conocer más sobre mi trayectoria</a>, o si lo tienes claro, ponte en contacto conmigo directamente para conocernos mejor.
      </p>
    </div>

    <div class="flex md:justify-end items-center">
      <a 
        href={`mailto:${email}`}
        class="group flex items-center gap-4 text-slate-950 hover:text-brand-coral transition-colors duration-300"
      >
        <span class="text-xl md:text-2xl font-light tracking-tight underline decoration-slate-200 underline-offset-8 group-hover:decoration-brand-coral transition-all">
         Empezar una conversación
        </span>
        <div class="w-12 h-12 rounded-full border border-slate-200 flex items-center justify-center group-hover:border-brand-coral group-hover:bg-brand-coral group-hover:text-white transition-all duration-300">
          <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
          </svg>
        </div>
      </a>
    </div>
  </div>

  <div class="flex flex-wrap gap-x-10 gap-y-6 text-slate-500 font-light text-sm items-center">
    <a href={`mailto:${email}`} class="hover:text-brand-coral transition-colors underline decoration-slate-200 underline-offset-4">{email}</a>
    <a href={`tel:${tlf.replace(/\s+/g, '')}`} class="hover:text-brand-coral transition-colors underline decoration-slate-200 underline-offset-4 tracking-wider">{tlf}</a>
    
    <div class="flex gap-5 items-center pl-2">
      <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="text-slate-950 hover:text-brand-coral transition-colors" aria-label="LinkedIn">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5c0 1.381-1.11 2.5-2.48 2.5s-2.48-1.119-2.48-2.5c0-1.38 1.11-2.5 2.48-2.5s2.48 1.12 2.48 2.5zm.02 4.5h-5v16h5v-16zm7.982 0h-4.968v16h4.969v-8.399c0-4.67 6.029-5.052 6.029 0v8.399h4.988v-10.131c0-7.88-8.922-7.593-11.018-3.714v-2.155z"/></svg>
      </a>
      <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="text-slate-950 hover:text-brand-coral transition-colors" aria-label="GitHub">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
      </a>
    </div>

    <div class="ml-auto text-xs text-slate-400 uppercase tracking-widest">
      © {new Date().getFullYear()} — Designed & Coded by Ana
    </div>
  </div>
</footer>